
generator client {
  provider = "prisma-client-js"
}

// SQLite connection
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Your model 
model Item {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  category    String
  createdAt   DateTime @default(now())
  seller String @default("Anonymous")
}
model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}